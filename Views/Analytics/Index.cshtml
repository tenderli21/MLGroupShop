@model List<MLGroupShop.Models.Order>
@{
    ViewData["Title"] = "CRM Аналитика";
}
<a asp-controller="Home"
       asp-action="Index"
       class="btn btn-dark mb-4">

    Панель управления

</a>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet">

<style>

    body {
        background: #f5f7fb;
        font-family: 'Manrope', sans-serif;
    }

    .crm-page {
        padding-top: 40px;
        padding-bottom: 70px;
    }

    .page-title {
        font-size: 52px;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 12px;
    }

    .page-subtitle {
        color: #64748b;
        font-size: 18px;
        margin-bottom: 45px;
    }

    .crm-card {
        background: white;
        border-radius: 30px;
        padding: 35px;
        box-shadow: 0 10px 35px rgba(0,0,0,0.05);
        height: 100%;
    }

    .crm-title {
        font-size: 20px;
        font-weight: 700;
        color: #64748b;
        margin-bottom: 20px;
    }

    .crm-number {
        font-size: 48px;
        font-weight: 800;
        color: #2563eb;
    }

    .crm-green {
        color: #10b981;
    }

    .crm-dark {
        color: #0f172a;
    }

    .chart-block {
        background: white;
        border-radius: 30px;
        padding: 35px;
        margin-top: 35px;
        box-shadow: 0 10px 35px rgba(0,0,0,0.05);
    }

    .chart-title {
        font-size: 30px;
        font-weight: 800;
        margin-bottom: 30px;
        color: #0f172a;
    }

    .bar-wrapper {
        display: flex;
        align-items: end;
        gap: 30px;
        height: 320px;
        margin-top: 30px;
    }

    .bar-item {
        flex: 1;
        text-align: center;
    }

    .bar {
        width: 100%;
        border-radius: 20px 20px 0 0;
        background: linear-gradient(180deg, #3b82f6, #2563eb);
    }

    .bar-1 {
        height: 120px;
    }

    .bar-2 {
        height: 200px;
    }

    .bar-3 {
        height: 280px;
    }

    .bar-4 {
        height: 170px;
    }

    .bar-5 {
        height: 250px;
    }

    .bar-text {
        margin-top: 15px;
        font-weight: 700;
        color: #0f172a;
    }

    .clients-table {
        width: 100%;
        margin-top: 25px;
        border-collapse: collapse;
    }

        .clients-table th {
            background: #0f172a;
            color: white;
            padding: 18px;
            font-size: 16px;
        }

        .clients-table td {
            background: white;
            padding: 18px;
            border-bottom: 1px solid #edf2f7;
            font-size: 16px;
        }

    .status-good {
        background: rgba(16,185,129,0.12);
        color: #10b981;
        padding: 8px 16px;
        border-radius: 12px;
        font-weight: 700;
    }

</style>

<div class="container crm-page">

    <h1 class="page-title">
        CRM Аналитика
    </h1>

    <div class="page-subtitle">
        Статистика магазина, аналитика продаж и база клиентов
    </div>

    <div class="row g-4">

        <div class="col-lg-3">

            <div class="crm-card">

                <div class="crm-title">
                    Общая выручка
                </div>

                <div class="crm-number">
                    @String.Format("{0:N0}", ViewBag.TotalRevenue) ₽
                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="crm-card">

                <div class="crm-title">
                    Заказов за месяц
                </div>

                <div class="crm-number crm-green">
                    @ViewBag.TotalOrders
                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="crm-card">

                <div class="crm-title">
                    Новых клиентов
                </div>

                <div class="crm-number crm-dark">
                    @ViewBag.TotalClients
                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="crm-card">

                <div class="crm-title">
                    Средний чек
                </div>

                <div class="crm-number">
                    @Math.Round(ViewBag.AverageCheck, 0) ₽
                </div>

            </div>

        </div>

    </div>

    <div class="chart-block">

        <h2 class="mb-4 fw-bold">
            Самые популярные товары
        </h2>

        <div class="card shadow-lg border-0 rounded-4 p-5 mb-5">

            <canvas id="popularChart" height="120"></canvas>

        </div>

        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

        <script>

            const ctx =
            document.getElementById('popularChart');

            new Chart(ctx, {

            type: 'bar',

            data: {

            labels: [
            'Деловой костюм',
            'Спортивные штаны',
            'Водолазка',
            'Спортивный костюм',
            'Шорты летние',
            'Школьная блузка',
            'Фартук',
            'Брюки клеш'
            ],

            datasets: [{

            label: 'Количество покупок',

            data: [15, 11, 8, 14, 10, 7, 20, 9],

            borderRadius: 12

            }]

            },

            options: {

            responsive: true,

            plugins: {

            legend: {
            display: false
            }

            },

            scales: {

            y: {
            beginAtZero: true
            }

            }

            }

            });

        </script>

    </div>

    <div class="chart-block">

        <div class="chart-title">
            Список клиентов
        </div>

        <table class="clients-table">

            <thead>

                <tr>

                    <th>ФИО</th>
                    <th>Телефон</th>
                    <th>Количество заказов</th>
                    <th>Статус</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.CustomerName</td>

                        <td>@item.Phone</td>

                        <td>@item.Quantity</td>

                        <td>
                            <span class="status-good">
                                @item.Status
                            </span>
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>