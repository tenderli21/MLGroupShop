@{
    ViewData["Title"] = "Вход";
}

<h1>Вход</h1>

<form method="post">

    <div class="mb-3">
        <label>Логин</label>
        <input type="text"
               name="username"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Пароль</label>
        <input type="password"
               name="password"
               class="form-control" />
    </div>

    <button type="submit"
            class="btn btn-primary">
        Войти
    </button>

</form>

@if (ViewBag.Error != null)
{
    <p style="color:red">
        @ViewBag.Error
    </p>
}