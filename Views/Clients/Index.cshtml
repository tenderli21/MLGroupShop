@model dynamic

<div class="container mt-5">

    <h1 class="fw-bold mb-4">
        База клиентов
    </h1>

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <table class="table align-middle mb-0">

            <thead style="background:#08122f; color:white;">

                <tr>
                    <th>ФИО</th>
                    <th>Телефон</th>
                    <th>Адрес</th>
                    <th>Заказов</th>
                    <th>Общая сумма</th>
                    <th>Статус</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td class="fw-semibold">
                            @item.Name
                        </td>

                        <td>
                            @item.Phone
                        </td>

                        <td>
                            @item.Address
                        </td>

                        <td>
                            @item.OrdersCount
                        </td>

                        <td class="fw-bold text-primary text-nowrap">
                            @item.TotalMoney ₽
                        </td>

                        <td>

                            @if (item.TotalMoney >= 5000)
                            {
                                <span class="badge bg-success">
                                    VIP
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    Обычный
                                </span>
                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>